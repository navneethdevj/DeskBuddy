{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "moduleNameMapper": {
    "^@api/(.*)$": "<rootDir>/src/$1",
    "^@shared/(.*)$": "<rootDir>/../../packages/shared/src/$1"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/server.ts",
    "!src/app.ts",
    "!src/config/index.ts",
    "!src/sockets/socket.server.ts",
    "!src/sockets/socket.handlers.ts",
    "!src/**/*.router.ts"
  ],
  "coverageThreshold": {
    "global": {
      "lines": 70
    }
  }
}
